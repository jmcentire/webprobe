      "performance_budget": null
    }
  ],
  "dependencies": [
    "asyncio",
    "json",
    "time",
    "datetime",
    "pathlib",
    "webprobe.browser",
    "webprobe.config",
    "webprobe.llm_provider",
    "webprobe.mask",
    "webprobe.models",
    "webprobe.visual"
  ],
  "dependency_contracts": {
    "webprobe.browser": [
      "BrowserPool"
    ],
    "webprobe.config": [
      "WebprobeConfig"
    ],
    "webprobe.llm_provider": [
      "CostTracker",
      "LLMProvider",
      "create_provider",
      "transmogrify_prompt"
    ],
    "webprobe.mask": [
      "MaskConfig",
      "apply_mask",
      "load_mask"
    ],
    "webprobe.models": [
      "AuthContext",
      "Node",
      "NodeCapture",
      "PhaseStatus",
      "SecurityCategory",
      "SecurityFinding",
      "SecuritySeverity",
      "SiteGraph"
    ],
    "webprobe.visual": [
      "analyze_screenshot",
      "check_contrast_from_page",
      "detect_hidden_elements"
    ]
  },
  "invariants": [
    "_AGENT_SYSTEM constant defines the agent's role and behavior rules",
    "_AGENT_OBSERVE constant template for formatting agent observations",
    "Agents use fake test data, never real personal information",
    "Agents avoid destructive actions (delete/remove/cancel-account)",
    "Maximum 40 interactive elements extracted per page",
    "Text truncated to 2000 characters for LLM context",
    "Href attributes truncated to 80 characters",
    "Console log limited to last 10 messages per iteration",
    "One screenshot analysis per node maximum",
    "SecurityFinding severity for agent observations is medium",
    "SecurityFinding severity for failed actions is low",
    "SecurityFinding category defaults to information_disclosure",
    "AuthContext defaults to anonymous for agent-generated findings",
    "Navigation timeout is 30000ms for initial load, 15000ms for agent navigation",
    "Click/fill timeout is 5000ms",
    "Networkidle wait state used after clicks",
    "Scroll delta is 500 pixels",
    "Phase name is 'explore'"
  ],
  "requires": [],
  "processing_register": "",
  "data_access": {
    "reads": [
      "SiteGraph nodes",
      "Screenshot files",
      "Mask configuration files",
      "Web page DOM and console"
    ],
    "writes": [
      "SecurityFinding objects",
      "PhaseStatus objects"
    ],
    "rationale": "Exploration phase reads site graph and artifacts, interacts with web pages via browser automation and LLM APIs, and produces security findings",
    "side_effects": [
      {
        "type": "network_call",
        "classification": "external",
        "fields": [
          "LLM API",
          "web pages"
        ],
        "rationale": "Makes HTTP requests to LLM providers and navigates to web pages"
      },
      {
        "type": "browser_automation",
        "classification": "external",
        "fields": [
          "page interactions"
        ],
        "rationale": "Clicks, fills forms, scrolls, and navigates browser pages"
      },
      {
        "type": "file_read",
        "classification": "local",
        "fields": [
          "screenshots",
          "mask files"
        ],
        "rationale": "Reads screenshots for visual analysis and mask files for filtering"
      }
    ]
  },
  "authority": {
    "domains": [
      "exploration",
      "llm_agents",
      "security_findings"
    ],
    "rationale": "This module owns the LLM-driven exploration phase logic, agent behavior, and findings generation from exploration"
  }
}