      "description": "Initializes ExploreConfig with exploration phase settings including LLM provider, concurrency, analysis toggles, and agent behavior limits.",
      "inputs": [
        {
          "name": "self",
          "type_ref": "ExploreConfig",
          "required": true,
          "default": "",
          "description": "Instance being initialized",
          "validators": []
        },
        {
          "name": "provider",
          "type_ref": "str",
          "required": false,
          "default": "anthropic",
          "description": "LLM provider name",
          "validators": []
        },
        {
          "name": "model",
          "type_ref": "str | None",
          "required": false,
          "default": "None",
          "description": "Specific model name or None",
          "validators": []
        },
        {
          "name": "concurrency",
          "type_ref": "int",
          "required": false,
          "default": "5",
          "description": "Concurrent agent count",
          "validators": []
        },
        {
          "name": "concurrency_warn_threshold",
          "type_ref": "int",
          "required": false,
          "default": "20",
          "description": "Warn threshold for concurrency",
          "validators": []
        },
        {
          "name": "max_actions_per_agent",
          "type_ref": "int",
          "required": false,
          "default": "20",
          "description": "Max actions per agent",
          "validators": []
        },
        {
          "name": "visual_analysis",
          "type_ref": "bool",
          "required": false,
          "default": "True",
          "description": "Enable visual analysis",
          "validators": []
        },
        {
          "name": "contrast_check",
          "type_ref": "bool",
          "required": false,
          "default": "True",
          "description": "Enable contrast checking",
          "validators": []
        },
        {
          "name": "hidden_elements",
          "type_ref": "bool",
          "required": false,
          "default": "True",
          "description": "Enable hidden element detection",
          "validators": []
        },
        {
          "name": "mask_path",
          "type_ref": "str | None",
          "required": false,
