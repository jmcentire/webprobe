          "description": "Authentication configuration",
          "validators": []
        },
        {
          "name": "crawl",
          "type_ref": "CrawlConfig",
          "required": false,
          "default": "CrawlConfig()",
          "description": "Crawling behavior configuration",
          "validators": []
        },
        {
          "name": "capture",
          "type_ref": "CaptureConfig",
          "required": false,
          "default": "CaptureConfig()",
          "description": "Capture behavior configuration",
          "validators": []
        },
        {
          "name": "output_dir",
          "type_ref": "str",
          "required": false,
          "default": "\"./webprobe-runs\"",
          "description": "Directory for output files",
          "validators": []
        }
      ],
      "item_type": "",
      "variants": [],
      "inner_types": [],
      "description": "Top-level configuration container for all webprobe settings",
      "owner_component": "src_webprobe_config"
    }
  ],
  "functions": [
    {
      "name": "load_config",
      "description": "Load configuration from an explicit path, default search paths (./webprobe.yaml, ~/.webprobe/webprobe.yaml), or return defaults if no config file exists.",
      "inputs": [
        {
          "name": "path",
          "type_ref": "str | Path | None",
          "required": false,
          "default": "None",
          "description": "Optional explicit path to config file. If None, searches standard locations.",
          "validators": []
        }
      ],
      "output_type": "WebprobeConfig",
      "error_cases": [
        {
          "name": "explicit_path_not_found",
          "condition": "path is not None and Path(path).exists() returns False",
          "error_type": "FileNotFoundError",
          "error_data": {
            "message": "Config not found: {p}"
          }
        },
        {
          "name": "yaml_parsing_error",
          "condition": "YAML file contains invalid syntax",
          "error_type": "yaml.YAMLError",
          "error_data": {}
        },
        {
          "name": "pydantic_validation_error",
          "condition": "YAML structure does not match WebprobeConfig schema",
          "error_type": "pydantic.ValidationError",
          "error_data": {}
        },
        {
          "name": "file_read_error",
          "condition": "File exists but cannot be read (permissions, encoding issues)",
          "error_type": "IOError",
          "error_data": {}
        }
      ],
      "preconditions": [
        "If path is provided and not None, it will be converted to a Path object"
      ],
      "postconditions": [
        "Returns a valid WebprobeConfig instance",
        "If no config files found, returns WebprobeConfig with all default values",
        "If config file found, YAML is parsed and validated against Pydantic models"
      ],
      "idempotent": true,
      "is_async": false,
      "side_effects": [
        "Reads from filesystem"
      ],
      "structured_side_effects": [
        {
          "kind": "reads_file",
          "target": "Path(path) if provided, otherwise ./webprobe.yaml or ~/.webprobe/webprobe.yaml",
          "description": "Reads YAML configuration file from filesystem"
        }
      ],
      "performance_budget": null
    }
  ],
  "dependencies": [
    "pathlib",
    "typing",
    "yaml",
    "pydantic"
  ],
  "dependency_contracts": {},
  "invariants": [
    "_SEARCH_PATHS = [Path('webprobe.yaml'), Path.home() / '.webprobe' / 'webprobe.yaml'] - Fixed search order for config files",
    "All Pydantic models use BaseModel from pydantic v2",
    "Default values are immutable or use Field(default_factory=...) for mutable collections"
  ],
  "requires": [],
  "processing_register": "",
  "data_access": {
    "reads": [
      "filesystem"
    ],
    "writes": [],
    "rationale": "Reads configuration files from filesystem for application settings",
    "side_effects": [
      {
        "type": "file_read",
        "classification": "configuration",
        "fields": [
          "path",
          "yaml_content"
        ],
        "rationale": "Reads YAML configuration files from standard search paths or explicit path"
      }
    ]
  },
  "authority": {
    "domains": [],
    "rationale": null
  }
}