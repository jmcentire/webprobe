{
  "component_id": "src_webprobe_config",
  "name": "Webprobe Configuration Loader",
  "description": "Configuration loading module that reads YAML files from standard search paths and validates them using Pydantic v2 models. Provides structured configuration for authentication, crawling, and capture behavior with fallback to defaults.",
